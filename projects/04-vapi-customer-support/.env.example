# ============================================================
# Vapi Customer Support Agent (Alex) — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# Vapi
VAPI_API_KEY=YOUR_VAPI_API_KEY
VAPI_PHONE_NUMBER_ID=YOUR_VAPI_PHONE_NUMBER_ID

# n8n Webhook URLs (one per tool call)
N8N_WEBHOOK_URL_FAQ=https://your-n8n-instance.com/webhook/lookup-faq
N8N_WEBHOOK_URL_ACCOUNT=https://your-n8n-instance.com/webhook/lookup-account
N8N_WEBHOOK_URL_TICKET=https://your-n8n-instance.com/webhook/create-ticket
N8N_WEBHOOK_URL_ESCALATE=https://your-n8n-instance.com/webhook/escalate-call

# Airtable (FAQ knowledge base)
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.YOUR_AIRTABLE_TOKEN
AIRTABLE_BASE_ID=appYOUR_BASE_ID
AIRTABLE_FAQ_TABLE=FAQs

# HubSpot (ticket + CRM)
HUBSPOT_API_KEY=pat-na1-YOUR_HUBSPOT_PRIVATE_APP_TOKEN

# CRM account lookup endpoint
CREEKSOFTWARE_CRM_ENDPOINT=https://api.creeksoftware.example.com/accounts
