# ============================================================
# Multi-Agent Personal Assistant — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# n8n
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/YOUR_WEBHOOK_ID

# OpenAI
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY

# HubSpot
HUBSPOT_API_KEY=pat-na1-YOUR_HUBSPOT_PRIVATE_APP_TOKEN

# Gmail (Google OAuth 2.0)
GMAIL_CLIENT_ID=YOUR_GMAIL_CLIENT_ID.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=YOUR_GMAIL_CLIENT_SECRET
GMAIL_REFRESH_TOKEN=YOUR_GMAIL_REFRESH_TOKEN

# Google Calendar (Google OAuth 2.0)
GOOGLE_CALENDAR_ID=your.email@gmail.com
GOOGLE_CALENDAR_REFRESH_TOKEN=YOUR_CALENDAR_REFRESH_TOKEN

# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=+1YOUR_TWILIO_NUMBER

# Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_ALLOWED_USER_ID=YOUR_TELEGRAM_USER_ID
