# ============================================================
# Vapi Real Estate Booking Agent — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# Vapi
VAPI_API_KEY=YOUR_VAPI_API_KEY
VAPI_PHONE_NUMBER_ID=YOUR_VAPI_PHONE_NUMBER_ID

# n8n Webhook URLs (one per tool call)
N8N_WEBHOOK_URL_AVAILABILITY=https://your-n8n-instance.com/webhook/check-availability
N8N_WEBHOOK_URL_BOOKING=https://your-n8n-instance.com/webhook/create-booking
N8N_WEBHOOK_URL_SMS=https://your-n8n-instance.com/webhook/send-listing-sms

# Google Calendar (Service Account)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY=BASE64_ENCODED_SERVICE_ACCOUNT_JSON
GOOGLE_CALENDAR_ID=agent@maplecrestrealty.com

# Twilio (SMS confirmations)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=+1YOUR_TWILIO_NUMBER

# Google Sheets (lead log)
LEAD_SHEET_ID=YOUR_GOOGLE_SHEET_ID
