# ============================================================
# WhatsApp Lead Agent — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# n8n
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/YOUR_WEBHOOK_ID

# OpenAI
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY

# HubSpot
HUBSPOT_API_KEY=pat-na1-YOUR_HUBSPOT_PRIVATE_APP_TOKEN

# Booking
BOOKING_LINK=https://calendly.com/YOUR_USERNAME/30min
