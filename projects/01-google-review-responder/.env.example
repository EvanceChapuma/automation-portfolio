# ============================================================
# Google Review Responder — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# n8n
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/YOUR_WEBHOOK_ID

# OpenAI
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY

# Google Maps / Places API
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
GOOGLE_PLACE_ID=ChIJYOUR_PLACE_ID

# Google OAuth 2.0 (for My Business API)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REFRESH_TOKEN=YOUR_GOOGLE_REFRESH_TOKEN

# Google Sheets audit log
AUDIT_SHEET_ID=YOUR_GOOGLE_SHEET_ID
