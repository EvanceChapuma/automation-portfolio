# ─── Candidate Pipeline Automation — Zapier ──────────────────────────────────
# Copy this file to .env and fill in your values.
# Authentication credentials (API keys, OAuth tokens) are stored in Zapier's
# Connected Accounts — not in environment variables. The values below are
# configuration constants referenced in Zap steps.

# ─── Anthropic / Claude AI ────────────────────────────────────────────────────
# Used in step 3 (Webhooks by Zapier → POST to Anthropic API)
# Generate at: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Typeform ─────────────────────────────────────────────────────────────────
# The form ID for your Candidate CV Submission form
# Found in the Typeform URL: typeform.com/to/FORM_ID
TYPEFORM_FORM_ID=

# ─── Airtable ─────────────────────────────────────────────────────────────────
# Base ID — found in the Airtable API docs URL for your base:
# airtable.com/developers/web/api/introduction (shows appXXXXXXXXXXXXXX)
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# ─── Gmail / Recruitment Email ────────────────────────────────────────────────
# The "From" address for all candidate-facing emails
# Must be a Gmail address connected to Zapier's Google account
RECRUITMENT_EMAIL=recruitment@yourcompany.com

# ─── Company Branding ─────────────────────────────────────────────────────────
# Used in the acknowledgement email template (step 13)
COMPANY_NAME=Your Company Name
COMPANY_ADDRESS=123 Main Street, City, Country
COMPANY_TIMEZONE=Europe/London

# ─── Slack ────────────────────────────────────────────────────────────────────
# Channel for recruitment ops alerts (parse failures — Zap 02)
# Use the channel name (e.g. #recruitment-ops) or channel ID
SLACK_OPS_CHANNEL=#recruitment-ops

# Channel for the weekly pooled candidate digest (Zap 03)
SLACK_RECRUITMENT_CHANNEL=#recruitment

# ─── ClickUp ──────────────────────────────────────────────────────────────────
# These are stored in the Open Roles Airtable table per-role, not globally.
# List them here for reference during initial setup.
# Find List IDs: open a ClickUp list → copy the ID from the URL
# CLICKUP_DEFAULT_LIST_ID=

# ─── Zapier Plan Notes ────────────────────────────────────────────────────────
# Zap 01 (main pipeline) requires: Professional plan
#   - Paths by Zapier (step 9) requires Professional
#   - Delay by Zapier over 1 hour (step 14) requires Professional
#   - Webhooks by Zapier (step 3) requires Professional
#   - Code by Zapier (steps 4, 5, 8) requires Starter+
# Zap 02 (parse error handler) requires: Starter+
# Zap 03 (weekly digest) requires: Professional (for Code + multi-step)
