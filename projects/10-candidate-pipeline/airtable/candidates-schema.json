{
  "table_name": "Candidates",
  "description": "Primary record for every candidate who submits a CV through the Typeform intake form. One record per candidate (deduplication by email).",
  "fields": [
    {
      "name": "Name",
      "type": "Single line text",
      "primary": true,
      "required": true,
      "notes": "Full name from Typeform submission"
    },
    {
      "name": "Email",
      "type": "Email",
      "required": true,
      "notes": "Used as the deduplication key — searched before creating a new record"
    },
    {
      "name": "Phone",
      "type": "Phone number",
      "required": false
    },
    {
      "name": "Location",
      "type": "Single line text",
      "required": false,
      "notes": "City or region from Typeform"
    },
    {
      "name": "Current Title",
      "type": "Single line text",
      "required": false
    },
    {
      "name": "Years Experience",
      "type": "Number",
      "format": "Integer",
      "required": false
    },
    {
      "name": "Skills",
      "type": "Long text",
      "required": false,
      "notes": "Comma-separated list extracted by Claude AI from cover note and form fields"
    },
    {
      "name": "Seniority",
      "type": "Single select",
      "required": false,
      "options": ["Junior", "Mid", "Senior", "Lead", "Executive", "Unknown"],
      "notes": "Parsed by Claude AI"
    },
    {
      "name": "Role Type",
      "type": "Single select",
      "required": false,
      "options": ["Engineering", "Design", "Product", "Marketing", "Operations", "Sales", "Legal", "Finance", "Other"],
      "notes": "Must match Role Type options in the Open Roles table"
    },
    {
      "name": "Availability",
      "type": "Single select",
      "required": false,
      "options": ["Immediate", "1 Month", "3 Months", "Unknown"],
      "notes": "Parsed by Claude AI"
    },
    {
      "name": "AI Summary",
      "type": "Long text",
      "required": false,
      "notes": "One-sentence candidate profile generated by Claude AI"
    },
    {
      "name": "Cover Note",
      "type": "Long text",
      "required": false,
      "notes": "Raw cover note from Typeform — preserved as-submitted"
    },
    {
      "name": "LinkedIn URL",
      "type": "URL",
      "required": false
    },
    {
      "name": "CV File URL",
      "type": "URL",
      "required": false,
      "notes": "Typeform-hosted URL — may expire after the Zap run. Archive to Google Drive for permanent storage."
    },
    {
      "name": "Source",
      "type": "Single select",
      "required": false,
      "options": ["Typeform", "Referral", "LinkedIn", "Website", "Other"],
      "default": "Typeform"
    },
    {
      "name": "Status",
      "type": "Single select",
      "required": true,
      "options": [
        "New",
        "Needs Manual Review",
        "Shortlisted",
        "Pooled",
        "Contacted",
        "Interview Scheduled",
        "Rejected",
        "Offered",
        "Hired"
      ],
      "default": "New",
      "notes": "Source of truth for recruiter action tracking and the 3-day reminder filter"
    },
    {
      "name": "Match Score",
      "type": "Number",
      "format": "Percent",
      "required": false,
      "notes": "0–100 score from the skill overlap computation. Populated by the Zap on initial run."
    },
    {
      "name": "Matched Role",
      "type": "Link to another record",
      "linked_table": "Open Roles",
      "required": false,
      "notes": "Set when is_match=true"
    },
    {
      "name": "ClickUp Task ID",
      "type": "Single line text",
      "required": false,
      "notes": "Populated by step 10 (Create ClickUp Task) on the match path"
    },
    {
      "name": "ClickUp Task URL",
      "type": "URL",
      "required": false
    },
    {
      "name": "Recruiter Notified",
      "type": "Checkbox",
      "default": false,
      "notes": "Checked when ClickUp task is created in step 11"
    },
    {
      "name": "Reminder Sent",
      "type": "Checkbox",
      "default": false,
      "notes": "Checked in step 18 after Slack reminder fires — prevents duplicate reminders"
    },
    {
      "name": "Reminder Sent Date",
      "type": "Date",
      "required": false,
      "options": {
        "include_time": true,
        "time_format": "24h"
      }
    },
    {
      "name": "Submission Date",
      "type": "Date",
      "required": false,
      "options": {
        "include_time": true,
        "time_format": "24h"
      }
    },
    {
      "name": "Resubmission",
      "type": "Checkbox",
      "default": false,
      "notes": "Checked when an existing candidate submits again. Resubmission Date is also set."
    },
    {
      "name": "Resubmission Date",
      "type": "Date",
      "required": false
    },
    {
      "name": "Ops Alerted",
      "type": "Checkbox",
      "default": false,
      "notes": "Used by the parse error handler Zap (02) to prevent duplicate ops alerts"
    },
    {
      "name": "Role Interest (Raw)",
      "type": "Long text",
      "required": false,
      "notes": "Raw multi-select value from Typeform — preserved for reference alongside the AI-parsed Role Type"
    }
  ],
  "views": [
    {
      "name": "All Candidates",
      "type": "Grid",
      "sort": [{"field": "Submission Date", "direction": "desc"}]
    },
    {
      "name": "Shortlisted",
      "type": "Grid",
      "filter": {"Status": "Shortlisted"},
      "sort": [{"field": "Match Score", "direction": "desc"}]
    },
    {
      "name": "Talent Pool (Pooled)",
      "type": "Grid",
      "filter": {"Status": "Pooled"},
      "sort": [{"field": "Submission Date", "direction": "desc"}]
    },
    {
      "name": "Needs Manual Review",
      "type": "Grid",
      "filter": [
        {"field": "Status", "value": "Needs Manual Review"},
        {"field": "Ops Alerted", "value": false}
      ],
      "notes": "Used as the trigger view for Zap 02 (parse error handler)"
    },
    {
      "name": "Active Pipeline",
      "type": "Kanban",
      "group_by": "Status",
      "exclude_statuses": ["Pooled", "Rejected", "Hired"]
    }
  ]
}
