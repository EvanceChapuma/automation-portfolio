# ============================================================
# WhatsApp Event Registration System — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# n8n
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/YOUR_WEBHOOK_ID

# OpenAI (Vision / GPT-4o required)
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY

# Airtable
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.YOUR_AIRTABLE_TOKEN
AIRTABLE_BASE_ID=appYOUR_BASE_ID
AIRTABLE_EVENTS_TABLE=Events
AIRTABLE_ATTENDEES_TABLE=Attendees
AIRTABLE_SEATS_TABLE=Seats

# Payment verification
PAYMENT_TOLERANCE_PERCENT=5
